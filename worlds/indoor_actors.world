<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="indoor_world">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <model name="room_walls">
      <static>true</static>
      <link name="walls">
        <collision name="c_w1"><pose>10 0 1.5 0 0 0</pose><geometry><box><size>0.2 20 3</size></box></geometry></collision>
        <visual name="v_w1"><pose>10 0 1.5 0 0 0</pose><geometry><box><size>0.2 20 3</size></box></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual>

        <collision name="c_w2"><pose>-10 0 1.5 0 0 0</pose><geometry><box><size>0.2 20 3</size></box></geometry></collision>
        <visual name="v_w2"><pose>-10 0 1.5 0 0 0</pose><geometry><box><size>0.2 20 3</size></box></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual>

