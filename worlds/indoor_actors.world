    <actor name="a1"><skin><filename>walk.dae</filename><scale>1.0</scale></skin><animation name="w"><filename>walk.dae</filename><scale>1.0</scale></animation><script><loop>true</loop><auto_start>true</auto_start><trajectory id="0" type="w"><waypoint><time>0</time><pose>0 0 0 0 0 0</pose></waypoint><waypoint><time>20</time><pose>8 0 0 0 0 0</pose></waypoint><waypoint><time>40</time><pose>0 0 0 0 0 0</pose></waypoint></trajectory></script></actor>
