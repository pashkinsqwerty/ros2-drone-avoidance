      <collision name="c"><geometry><cylinder><radius>0.4</radius><length>1</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.4</radius><length>1</length></cylinder></geometry><material><ambient>1 0 0 1</ambient></material></visual>
    </link></model>
    <model name="c3"><static>true</static><link name="l">
